# ── AetherAI Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it is in .gitignore.

# ── Qwen API (DashScope — International endpoint) ────────────────────────────
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Qwen Vision Model (for vision loop screenshot analysis) ───────────────────
# Recommended: qwen-vl-plus or qwen-vl-max
# Falls back to QWEN_MODEL if not set (vision loop won't see the screen)
QWEN_VISION_MODEL=qwen-vl-plus

# ── Security ──────────────────────────────────────────────────────────────────
# Protects your cloud brain endpoints from unauthorized CLI/API access.
# Generate a key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Set this same key in Railway environment variables as AETHER_API_KEY.
# Also put it in device_agent/aether_config.ini as api_key (local only).
#
# The web UI at /ui/index.html fetches the key automatically — users
# visiting the URL don't need to enter anything.
AETHER_API_KEY=your_secret_api_key_here

# ── Database (set to /data/aether.db if using Railway persistent volume) ──────
DB_PATH=/data/aether.db

# ── Stage 6: New Agent API Keys ───────────────────────────────────────────────

# GNews API — free 100 req/day — get key at https://gnews.io
# Used by: news_agent for headlines and news briefings
# If not set, news_agent falls back to Hacker News (no key needed)
GNEWS_API_KEY=your_gnews_api_key_here

# Alpha Vantage — free 25 req/day — get key at https://www.alphavantage.co/support/#api-key
# Used by: finance_agent for stock prices
# If not set, stock lookups will show a message with the signup link
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# No key needed (already work out of the box):
#   Open-Meteo    → weather_agent (weather + forecasts)
#   CoinGecko     → crypto_agent (cryptocurrency prices)
#   ExchangeRate  → finance_agent (currency conversion)
#   Hacker News   → news_agent fallback
#   yt-dlp        → browser_agent YouTube (installed via requirements.txt)
#   trafilatura   → browser_agent + research_agent web scraping

# ── Server (Railway sets PORT automatically) ──────────────────────────────────
# PORT=8000
