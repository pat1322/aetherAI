# ── AetherAI Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it is in .gitignore.

# ── Qwen API (DashScope — International endpoint) ────────────────────────────
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Security ──────────────────────────────────────────────────────────────────
# Protects your cloud brain endpoints from unauthorized access.
# Generate a key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Set this same key in Railway environment variables as AETHER_API_KEY.
# Also put it in device_agent/aether_config.ini as api_key (local only, don't push).
AETHER_API_KEY=your_secret_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=../database/aether.db

# ── Server (Railway sets PORT automatically — leave commented out) ────────────
# PORT=8000
