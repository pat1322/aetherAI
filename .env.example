# ── AetherAI Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it is in .gitignore.

# ── Qwen API (DashScope — International endpoint) ────────────────────────────
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Qwen Vision Model (for vision loop / screenshot analysis) ─────────────────
# Set to a vision-capable model: qwen-vl-plus or qwen-vl-max
# If not set, falls back to QWEN_MODEL (text-only, vision loop won't see screen)
QWEN_VISION_MODEL=qwen-vl-plus

# ── Security ──────────────────────────────────────────────────────────────────
# Protects your cloud brain endpoints from unauthorized CLI/API access.
# Generate a key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Set this same key in Railway environment variables as AETHER_API_KEY.
# Also put it in device_agent/aether_config.ini as api_key (local only).
#
# The web UI at /ui/index.html fetches the key automatically — users
# visiting the URL don't need to enter anything.
AETHER_API_KEY=your_secret_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to <project_root>/database/aether.db (absolute, never relative)
# Only set this if you want to override the location.
# DB_PATH=/custom/path/to/aether.db

# ── Server (Railway sets PORT automatically — leave commented out) ────────────
# PORT=8000
