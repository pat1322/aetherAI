# ── AetherAI Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it is in .gitignore.

# ── Qwen API (DashScope — International endpoint) ────────────────────────────
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Qwen Vision Model (for vision loop screenshot analysis) ───────────────────
# Recommended: qwen-vl-plus or qwen-vl-max
# Falls back to QWEN_MODEL if not set
QWEN_VISION_MODEL=qwen-vl-plus

# ── Security ──────────────────────────────────────────────────────────────────
# Protects your cloud brain endpoints from unauthorized CLI/API access.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Set this same key in Railway AND in device_agent/aether_config.ini (local only).
AETHER_API_KEY=your_secret_api_key_here

# ── Database (set to /data/aether.db if using Railway persistent volume) ──────
DB_PATH=/data/aether.db

# ── Stage 6: Voice Agent ──────────────────────────────────────────────────────
# edge-tts voice for ESP32 voice responses + browser TTS readback.
# No API key needed — edge-tts is free (Microsoft neural voices).
#
# Good English voices:
#   en-US-AriaNeural      Female, neutral, expressive  (default)
#   en-US-GuyNeural       Male, neutral
#   en-US-JennyNeural     Female, friendly
#   en-GB-SoniaNeural     Female, British
#
# Filipino voices:
#   fil-PH-BlessicaNeural Female, Filipino
#   fil-PH-AngeloNeural   Male, Filipino
#
# List all:  python -m edge_tts --list-voices
TTS_VOICE=en-US-AriaNeural

# ── Stage 6: News & Finance API Keys ──────────────────────────────────────────

# Serper.dev — Google Search API, free 2500 queries/month, no credit card needed
# Get key at: https://serper.dev  (Sign up → dashboard → API Key)
# Without this key it falls back to SearXNG public instances (still works, no key needed)
SERPER_API_KEY=your_serper_api_key_here

# GNews API — free 100 req/day — https://gnews.io
GNEWS_API_KEY=your_gnews_api_key_here

# Alpha Vantage — free 25 req/day — https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# ── No key needed (work out of the box) ──────────────────────────────────────
#   Open-Meteo    → weather_agent
#   CoinGecko     → crypto_agent
#   ExchangeRate  → finance_agent (currency)
#   Hacker News   → news_agent fallback
#   Paraformer    → stt_client  (reuses QWEN_API_KEY via DashScope)
#   edge-tts      → tts_client  (free, no key)

# ── Server (Railway sets PORT automatically) ──────────────────────────────────
# PORT=8000
