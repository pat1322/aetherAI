#pragma once

// ── WiFi ─────────────────────────────────────────────────────────────────────
#define WIFI_SSID       "your_wifi_ssid"
#define WIFI_PASSWORD   "your_wifi_password"

// ── AetherAI Cloud Brain (Railway) ───────────────────────────────────────────
// NO trailing slash
#define AETHER_URL      "https://your-app.up.railway.app"
#define AETHER_API_KEY  "your_railway_api_key"

// ── Qwen / DashScope API Key ─────────────────────────────────────────────────
// Same key used for:
//   • Qwen LLM (on Railway)
//   • Paraformer Real-time ASR (on ESP32 — this firmware)
// Get it from: console.aliyun.com → DashScope → API Keys
// It starts with "sk-"
#define QWEN_API_KEY    "sk-your_dashscope_api_key_here"

// ── VAD Threshold ─────────────────────────────────────────────────────────────
// TFT shows "mic peak=XXX thr=2000" every 8s to help tune this.
// Raise if Bronny triggers on background noise.
// Lower if Bronny doesn't trigger when you speak.
// Range: 1500 (quiet room) → 4000 (noisy room)
#define BRONNY_VAD_THR  2000
