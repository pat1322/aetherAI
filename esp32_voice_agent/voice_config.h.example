/*
 * ╔══════════════════════════════════════════════════════════════╗
 * ║      AetherAI / Bronny AI v7.0 — Config Template            ║
 * ╠══════════════════════════════════════════════════════════════╣
 * ║  SETUP:                                                      ║
 * ║   1. Copy this file → voice_config.h                         ║
 * ║   2. Fill in all values below                                ║
 * ║   3. voice_config.h is in .gitignore — NEVER committed       ║
 * ╚══════════════════════════════════════════════════════════════╝
 */

#pragma once

// ── WiFi ─────────────────────────────────────────────────────────────────────
#define WIFI_SSID       "your_wifi_ssid_here"
#define WIFI_PASSWORD   "your_wifi_password_here"

// ── AetherAI Cloud Brain (Railway) ───────────────────────────────────────────
// Your Railway deployment URL — NO trailing slash
// Example: "https://aetherai.up.railway.app"
#define AETHER_URL      "https://your-app.up.railway.app"

// Must match AETHER_API_KEY in Railway environment variables
#define AETHER_API_KEY  "your_secret_api_key_here"

// ── BytePlus Seed Speech — Streaming ASR ────────────────────────────────────
//
// API docs: docs.byteplus.com/en/docs/byteplusvoice/asrstreaming
// Console:  console.byteplus.com
//
// Auth headers on WebSocket upgrade (Seed Speech API):
//   X-Api-App-Key:    APP ID
//   X-Api-Access-Key: ACCESS TOKEN
//   X-Api-Key:        UUID API KEY  (new single-key method — recommended)
//   X-Api-Resource-Id:API Resource ID (volc.bigasr.sauc.duration etc.)
//   X-Api-Connect-Id: any UUID (connection tracking)
//
#define BYTEPLUS_APP_ID   "your_numeric_app_id_here"      // APP ID from console
#define BYTEPLUS_TOKEN    "your_access_token_here"        // ACCESS TOKEN from console
#define BYTEPLUS_API_KEY  "your_uuid_api_key_here"        // UUID API KEY from console
                                                          // e.g. "597a6e93-df07-43d7-be40-e728500db3b9"

// ── API Resource ID ──────────────────────────────────────────────────────────
// From console → API Reference → API Resource ID
//   Seed ASR 1.0: "volc.bigasr.sauc.duration"   ← recommended
//   Seed ASR 2.0: "volc.seedasr.sauc.duration"
// This goes in X-Api-Resource-Id header only. NOT in the JSON body.
#define BYTEPLUS_RESOURCE_ID  "volc.bigasr.sauc.duration"

// ── ASR Language ─────────────────────────────────────────────────────────────
// From docs: leave empty for auto (supports Cantonese, Shanghainese, Minnan etc.)
// Or set a specific language:
//   "en-US"   English
//   "fil-PH"  Filipino  ← useful for Tagalog
//   "zh-CN"   Mandarin
// Leave empty "" for automatic multilingual detection
#define BYTEPLUS_LANGUAGE "en-US"

// ── ASR Endpoint ─────────────────────────────────────────────────────────────
// Seed Speech streaming (unidirectional, client streams audio to server):
//   Host: openspeech.byteoversea.com
//   Path: /api/v3/sauc/bigmodel_nostream
#define BYTEPLUS_ASR_HOST "openspeech.byteoversea.com"
#define BYTEPLUS_ASR_PATH "/api/v3/sauc/bigmodel_nostream"

// ── VAD Threshold ─────────────────────────────────────────────────────────────
// Adjust if Bronny is too sensitive (raise) or not triggering (lower).
// Typical range: 1500 (quiet room) to 4000 (noisy environment).
// Serial monitor shows "[VAD] peak=XXX thr=XXXX" every 3s to help calibrate.
#define BRONNY_VAD_THR  2000
